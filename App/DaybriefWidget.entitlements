<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  Entitlements for the desktop widget extension.

  Unlike the host, the widget MUST be App-Sandboxed — a non-sandboxed widget
  extension fails to register with the widget system and never appears in the
  gallery. Sandboxed, it can reach nothing on disk EXCEPT the shared App Group
  container, which is exactly where the host writes the brief snapshot. It never
  holds OAuth tokens, the LLM key, or the SQLCipher key, and never opens the
  encrypted database. The group id is team-prefixed at build time so no literal
  team ID is committed. See docs/build/widget.md.
-->
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>$(DAYBRIEF_APP_GROUP)</string>
	</array>
</dict>
</plist>
